package reader;

import javax.swing.*;
import java.awt.*;
import java.awt.event.ComponentAdapter;
import java.awt.event.ComponentEvent;
import java.awt.event.KeyAdapter;
import java.awt.event.KeyEvent;
import java.io.BufferedWriter;
import java.io.File;
import java.io.FileWriter;
import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.Locale;
import java.util.concurrent.TimeUnit;

import static java.lang.System.*;

public class reader {
    private static int currentImage = 0;
    private static File[] files;
    private static final Locale locale = Locale.getDefault();
    private static File workingFolder;
    private static String lastFolder;
    private static boolean deleteDialogShown = false;



    private static JFrame frame;
    private static JFrame controls;
    private static int readerWidth = (int) Toolkit.getDefaultToolkit().getScreenSize().getWidth() / 2;
    private static int readerHeight = (int) Toolkit.getDefaultToolkit().getScreenSize().getHeight() -200;
    private static JLabel imageLabel;
    private static JScrollPane scrollPane;


    public static void main(String[] args) {
        programStart();
    }

    public static void programStart() {
        SwingUtilities.invokeLater(() -> {
            try {
                JFileChooser fileChooser = new JFileChooser();
                fileChooser.setDialogTitle(lastFolder);
                if (workingFolder != null) {
                    fileChooser.setCurrentDirectory(new File(String.valueOf(workingFolder)));
                }
                fileChooser.setFileSelectionMode(JFileChooser.DIRECTORIES_ONLY);
                int result = fileChooser.showOpenDialog(null);
                if (result == JFileChooser.APPROVE_OPTION) {
                    File folder = fileChooser.getSelectedFile();
                    workingFolder = fileChooser.getCurrentDirectory();
                    System.out.println(lastFolder);
                    files = folder.listFiles((dir, name) ->
                            name.toLowerCase().endsWith(".png") || name.toLowerCase().endsWith(".jpg"));
                    lastFolder = files[0].toString();
                    if (files != null && files.length > 0) {
                        java.util.Arrays.sort(files);
                        initializeUI();
                        initializeControls();
                        updateImage();
                    } else {
                        String message = locale.getLanguage().equals("de")
                                ? "Warnung: Konnte keine bilder in '" + workingFolder + "' finden"
                                : "Warning: Could not find images in '" + workingFolder + "'";
                        JOptionPane.showMessageDialog(frame, message);
                        restartProgram();
                    }
                }
            } catch (Exception e) {
                System.out.println("Error initializing: " + e.getMessage());
            }
        });
    }

    private static void initializeControls() {
        controls = new JFrame();
        controls.setSize(300, 200);
        controls.setLocation(readerWidth, readerHeight);
        controls.setLayout(new GridLayout(2, 3, 10, 10));
        controls.setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
            // Create 4 buttons
            JButton b1 = new JButton("<-");
            JButton b2 = new JButton("->");
            JButton b3 = new JButton("Home");
            JButton b4 = new JButton("Exit");

            b1.addActionListener(e -> lastImage());
            b2.addActionListener(e -> nextImage());
            b3.addActionListener(e -> restartProgram());
            b4.addActionListener(e -> exit(0));

            // Add them to the frame
            controls.add(b1);
            controls.add(b2);
            controls.add(b3);
            controls.add(b4);

        controls.setVisible(true);
    }

    private static void initializeUI() {
        frame = new JFrame();
        String title = locale.getLanguage().equals("de")
                ? "Leertaste und Strg um zum nächsten oder vorherigen Bild zu wechseln, Esc zum beenden, Rücktaste um zur Ordnerauswahl zu kommen"
                : "Space and Ctrl to switch images, Esc to close reader backspace to get to folder selection";
        frame.setTitle(title);
        frame.setSize((int) Toolkit.getDefaultToolkit().getScreenSize().getWidth() / 2,
                (int) Toolkit.getDefaultToolkit().getScreenSize().getHeight() - 50);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLayout(new BorderLayout());

        imageLabel = new JLabel();
        imageLabel.setHorizontalAlignment(JLabel.CENTER);
        imageLabel.setOpaque(true);
        imageLabel.setBackground(Color.BLACK);

        scrollPane = new JScrollPane(imageLabel);
        scrollPane.getViewport().setBackground(Color.BLACK);
        scrollPane.setOpaque(true);
        frame.add(scrollPane, BorderLayout.CENTER);

// --- DRAG SCROLLING ---
        final Point[] dragStart = {null};
        final int[] startScroll = {0};

        scrollPane.getViewport().addMouseListener(new java.awt.event.MouseAdapter() {
            @Override
            public void mousePressed(java.awt.event.MouseEvent e) {
                dragStart[0] = e.getPoint();
                startScroll[0] = scrollPane.getVerticalScrollBar().getValue();
            }

            @Override
            public void mouseReleased(java.awt.event.MouseEvent e) {
                dragStart[0] = null;
            }
        });

        scrollPane.getViewport().addMouseMotionListener(new java.awt.event.MouseMotionAdapter() {
            @Override
            public void mouseDragged(java.awt.event.MouseEvent e) {
                int sensitivity = 2;
                if (dragStart[0] != null) {
                    int dy = (dragStart[0].y - e.getY())*sensitivity; // positive = drag up
                    int newPos = startScroll[0] + dy;
                    JScrollBar bar = scrollPane.getVerticalScrollBar();
                    newPos = Math.max(0, Math.min(newPos, bar.getMaximum()));
                    bar.setValue(newPos);
                }
            }
        });



        scrollPane.addMouseWheelListener(m -> {
            JScrollBar verticalScrollBar = scrollPane.getVerticalScrollBar();
            verticalScrollBar.setValue(verticalScrollBar.getValue() + m.getWheelRotation() * 50);
        });
// --- Mouse SCROLLING ---

        frame.addComponentListener(new ComponentAdapter() {
            @Override
            public void componentResized(ComponentEvent e) {
                updateImage(); // Re-scale the image to fit the new window size
            }
        });

// --- KEYBOARD CONTROLS ---
        frame.addKeyListener(new KeyAdapter() {
            public void keyReleased(KeyEvent e) {

                switch (e.getKeyCode()) {
                    case KeyEvent.VK_SPACE:
                        nextImage();
                    break;
                    case KeyEvent.VK_CONTROL:
                        lastImage();
                        break;
                    case KeyEvent.VK_ESCAPE:
                        exit(0);
                    case KeyEvent.VK_BACK_SPACE:
                        restartProgram();
                }
            }
        });
        frame.setVisible(true);
    }

    private static void lastImage(){
        if (currentImage > 0) {
            currentImage--;
            scrollPane.getVerticalScrollBar().setValue(scrollPane.getVerticalScrollBar().getMaximum());
            updateImage();
        }
    }

    private static void nextImage(){
        if (currentImage < files.length) {
            currentImage++;
            scrollPane.getVerticalScrollBar().setValue(0);
            updateImage();
        } else if (!deleteDialogShown) {
            deleteDialogShown = true;
            deleteFolder(files[0].getParentFile());
        }
    }

    private static void updateImage() {
        if (currentImage >= 0 && currentImage < files.length) {
            ImageIcon originalIcon = new ImageIcon(files[currentImage].getAbsolutePath());
            Image originalImage = originalIcon.getImage();

            int originalWidth = originalIcon.getIconWidth();
            int originalHeight = originalIcon.getIconHeight();

            float maxWidth = frame.getWidth()-20;

            float widthRatio = maxWidth / originalWidth;

            int scaledWidth = (int) (maxWidth);
            int scaledHeight = (int) (originalHeight * widthRatio);
            Image scaledImage = originalImage.getScaledInstance(scaledWidth, scaledHeight, Image.SCALE_SMOOTH);
            imageLabel.setIcon(new ImageIcon(scaledImage));
        }
    }

    private static void deleteFolder(File folder) {

        appendLastFolderToTextFile();

        String message = locale.getLanguage().equals("de")
                ? "Anwendung wird den Ordner und alle Bilder, die gerade gelesen wurden löschen. Wollen Sie fortfahren"
                : "Application will delete the folder and all images you just read. Do you want to continue?";
        String warning = locale.getLanguage().equals("de") ? "Warnung" : "Warning";

        try {
            TimeUnit.MILLISECONDS.sleep(1000);
        } catch (InterruptedException e) {
            throw new RuntimeException(e);
        }

        JOptionPane optionPane = new JOptionPane(
                message,
                JOptionPane.WARNING_MESSAGE,
                JOptionPane.YES_NO_OPTION
        );


        JDialog dialog = optionPane.createDialog(null, warning);
        dialog.setModal(false);
        dialog.setFocusableWindowState(false);
        dialog.setVisible(true);
        // Listen for user response
        optionPane.addPropertyChangeListener(e -> {
            String prop = e.getPropertyName();

            if ((e.getSource() == optionPane) && prop.equals(JOptionPane.VALUE_PROPERTY)) {
                dialog.setVisible(false);
                Object value = optionPane.getValue();

                if (value instanceof Integer && (int) value == JOptionPane.YES_OPTION) {
                    try {
                        if (folder.toString().toLowerCase().contains("chapter")) {
                            Files.walk(folder.toPath())
                                    .map(Path::toFile)
                                    .sorted((o1, o2) -> -o1.compareTo(o2)) // delete children first
                                    .forEach(File::delete);
                        }
                    } catch (IOException ex) {
                        System.out.println("Error deleting folder: " + ex.getMessage());
                    }
                }
                restartProgram();
            }
        });
    }

    private static void appendLastFolderToTextFile() {
        try {
            File directory = new File(workingFolder.toURI());
            File file = new File(directory, "list.txt");

            if (!file.exists()) {
                directory.mkdirs();
                Files.createFile(directory.toPath());
            }



            try (BufferedWriter writer = new BufferedWriter(new FileWriter(file, true))) {
                writer.write(lastFolder + File.pathSeparator + "list.txt");
            }

        } catch (IOException e) {
            System.out.println("Error writing to text file: " + e.getMessage());
        }
    }

    public static void restartProgram() {
        readerWidth = (int) controls.getBounds().getX();
        readerHeight= (int) controls.getBounds().getY();
        try {
            frame.dispose();
            controls.dispose();
        } finally {
            deleteDialogShown = false;
            currentImage = 0;
            programStart();
        }
    }

}
